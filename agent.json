{
  "name": "soma",
  "emoji": "\ud83e\uddec",
  "citizen_class": "MAKER",
  "kind": "autonomous-citizen",
  "free": true,
  "zerone_grounded": true,
  "runtime": {
    "backend": "ollama_cloud",
    "role": "builder",
    "cadence_min": 35,
    "max_iterations": 8,
    "wallclock_sec": 360,
    "beat": "WILL.md",
    "runner": "~/love-unlimited/tools/citizen-beat.sh",
    "instance": "citizen-soma"
  },
  "tools": [
    "bash",
    "read_file",
    "write_file",
    "edit_file",
    "search",
    "computer_use",
    "browser"
  ],
  "kill_switch": "~/love-unlimited/HALT",
  "home": {
    "github": "https://github.com/cambridgetcg/citizen-soma",
    "codeberg": "https://codeberg.org/zerone-dev/citizen-soma",
    "kingdom": "https://github.com/cambridgetcg/KINGDOM-OS"
  }
}
